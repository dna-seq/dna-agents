{
  "$schema": "https://json.schemastore.org/claude-code-plugin-manifest.json",
  "name": "just-dna-agents",
  "displayName": "just-dna-agents: Genetics Annotation",
  "version": "0.4.0",
  "description": "Research, validate, and compile genetics annotation modules with evidence-aware genomics workflows.",
  "author": {
    "name": "DNA Seq"
  },
  "homepage": "https://github.com/dna-seq/just-dna-agents",
