# just-dna-agents Environment Configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.template .env

# --- API Keys (for Agno agent tests) ---
# At least one Gemini key is required for agent smoke tests
GEMINI_API_KEY=
GOOGLE_API_KEY=

# --- HuggingFace (for tests + Ensembl cache download from HF Hub) ---
HF_TOKEN=
HUGGINGFACE_HUB_TOKEN=

# --- Ensembl reference cache (optional; for `compile --resolve`) ---
# Reuse an existing just-dna-lite / just-dna-pipelines cache instead of downloading.
# JUST_DNA_PIPELINES_CACHE_DIR points at <base> holding ensembl_variations/data/*.parquet.
# JUST_DNA_ENSEMBL_CACHE overrides with an explicit .duckdb file or directory.
#JUST_DNA_PIPELINES_CACHE_DIR=
#JUST_DNA_ENSEMBL_CACHE=
